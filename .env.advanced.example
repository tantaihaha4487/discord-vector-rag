# Discord app
BOT_TOKEN=
CLIENT_ID=
GUILD_ID=

# Chat fallback order
# Providers without API keys are skipped.
AI_PROVIDERS=openrouter,nvidia,openai,groq

# OpenRouter
AI_PROVIDER_OPENROUTER_API_KEY=
AI_PROVIDER_OPENROUTER_MODEL=google/gemma-4-31b-it:free
AI_PROVIDER_OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# NVIDIA
AI_PROVIDER_NVIDIA_API_KEY=
AI_PROVIDER_NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
AI_PROVIDER_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
AI_PROVIDER_NVIDIA_TEMPERATURE=1
AI_PROVIDER_NVIDIA_TOP_P=0.95
AI_PROVIDER_NVIDIA_MAX_TOKENS=16384
AI_PROVIDER_NVIDIA_REASONING_ENABLED=true
AI_PROVIDER_NVIDIA_REASONING_EFFORT=high

# OpenAI
AI_PROVIDER_OPENAI_API_KEY=
AI_PROVIDER_OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Groq
AI_PROVIDER_GROQ_API_KEY=
AI_PROVIDER_GROQ_MODEL=llama-3.3-70b-versatile

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=discord_vector_rag
QDRANT_INDEX_ID=discord-vector-rag
QDRANT_API_KEY=

# Embeddings
# Default is local Ollama and does not need an API key.
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Retrieval debug logs
RAG_DEBUG_RETRIEVAL=false
